# Application Environment
NODE_ENV=development

# Server Configuration
PORT=3001
HOST=127.0.0.1

# Data Directory (optional, overrides default)
DATA_DIR=

# Session Configuration
SESSION_SECRET=change-me-in-production
SESSION_MAX_AGE=86400000

# Logging
LOG_LEVEL=info

# Security
# Set to 'true' only when serving behind HTTPS
SECURE_COOKIES=false

# Rate Limiting (requests per window)
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_EXPORT_MAX=10
RATE_LIMIT_LOGIN_MAX=10

# Upload Limits (bytes)
UPLOAD_MAX_SIZE=10485760
UPLOAD_IMPORT_MAX_SIZE=52428800
UPLOAD_BRANDING_MAX_SIZE=2097152

# PDF Generation
PDF_TIMEOUT=30000
PUPPETEER_TIMEOUT=30000

# Cache TTL (seconds)
CACHE_TEMPLATE_TTL=300
CACHE_CONFIG_TTL=60
CACHE_I18N_TTL=3600

# Database
DB_BUSY_TIMEOUT=5000

# Webhook Configuration
WEBHOOK_TIMEOUT=5000
WEBHOOK_RETRY_DELAY=30000
