{
  "name": "auditorlibre",
  "version": "1.0.0",
  "description": "Auditor Libre - an audit template builder and executor",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "start:prod": "cross-env NODE_ENV=production HOST=0.0.0.0 node server.js",
    "check:prod": "node scripts/check-production.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test mocha --file ./test/setup.js \"test/**/*.test.js\" --exit",
    "test:coverage": "cross-env NODE_ENV=test nyc mocha --file ./test/setup.js \"test/**/*.test.js\" --exit",
    "test:watch": "cross-env NODE_ENV=test mocha --file ./test/setup.js --watch \"test/**/*.test.js\" --exit",
    "lint": "eslint .",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs auditor-libre"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.5",
    "env-paths": "^3.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-notifier": "^10.0.1",
    "puppeteer": "^21.0.0",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "chai": "^4.4.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "mocha": "^10.3.0",
    "nodemon": "^3.0.0",
    "nyc": "^15.1.0",
    "pm2": "^5.3.1",
    "supertest": "^6.3.4"
  }
}
