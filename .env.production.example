# OPENAUDITOR production example

NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Use a persistent path in your server or mounted volume
DATA_DIR=/data

LOG_LEVEL=info

# Set to true only if you publish behind HTTPS
SECURE_COOKIES=false

# Reserved for future external auth / proxy integrations
SESSION_SECRET=change-me-if-you-need-it-later
SESSION_MAX_AGE=86400000

PDF_TIMEOUT=30000
PUPPETEER_TIMEOUT=30000
DB_BUSY_TIMEOUT=5000
WEBHOOK_TIMEOUT=5000
WEBHOOK_RETRY_DELAY=30000
